# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/ai_agency_platform

# Anthropic
ANTHROPIC_API_KEY=

# GoHighLevel
GHL_API_KEY=
GHL_AGENCY_ID=
GHL_BASE_URL=https://services.leadconnectorhq.com

# N8N
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Voice (Bland.ai)
BLAND_API_KEY=

# LinkedIn (Phantombuster)
PHANTOMBUSTER_API_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Encryption (32-byte hex string for AES-256)
ENCRYPTION_KEY=

# Email (Gmail OAuth2)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://api.nodusaisystems.com/onboarding/oauth/gmail/callback

# OAuth — Social Media
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=nodus_engage_verify
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# OAuth — CRM
GHL_OAUTH_CLIENT_ID=
GHL_OAUTH_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# App URLs (used for OAuth callbacks)
API_BASE_URL=https://api.nodusaisystems.com
PORTAL_BASE_URL=https://app.nodusaisystems.com

# App
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Buffer — schedules LinkedIn, Facebook, Instagram, Twitter/X
# Sign up at buffer.com, connect your social accounts, then get token from buffer.com/developers
BUFFER_API_URL=https://api.bufferapp.com/1

# Meta Graph API — Facebook Pages + Instagram Business posting
# Setup: developers.facebook.com → Create App → Add Facebook Login + Instagram Graph API
# Permissions needed: pages_manage_posts, instagram_basic, instagram_content_publish, pages_read_engagement
META_GRAPH_API_URL=https://graph.facebook.com/v18.0
# META_PAGE_ACCESS_TOKEN is stored per-client (encrypted in DB) — no global token needed here

# Instagram — per-client credentials (stored encrypted in DB at onboarding)
# instagram_user_id: found via GET /{page-id}?fields=instagram_business_account
# instagram_access_token: same Page Access Token used for Meta above

# TikTok Content Posting API v2
# Setup: developers.tiktok.com → Create App → Add "Content Posting API" product
# OAuth scopes required: video.upload, video.publish, video.list
# Redirect URI: {API_BASE_URL}/webhooks/tiktok/oauth-callback
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
# Per-client access_token and open_id stored encrypted in DB after OAuth

# JWT
JWT_SECRET=

# API Port
PORT=4000

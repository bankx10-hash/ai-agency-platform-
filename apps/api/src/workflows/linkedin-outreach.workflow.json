    {
      "id": "4563c5d9-54a7-4d2e-9827-878b0a9158db",
      "name": "Build Classify Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 600],
      "parameters": {
        "jsCode": "const parsed = $('Parse PB Conversation').first().json;\nconst contactData = $('Look Up Contact').first().json;\nconst message = parsed.message || '';\nconst contactId = contactData.id || (contactData.contact && contactData.contact.id) || null;\nreturn [{\n  json: {\n    model: 'claude-haiku-4-5-20251001',\n    max_tokens: 300,\n    system: 'You are a LinkedIn reply classifier. Analyse the reply and return ONLY valid JSON with no extra text.',\n    messages: [{ role: 'user', content: 'Classify this LinkedIn reply. Return ONLY valid JSON: {\"intent\":\"interested|not_interested|question|other\",\"responseMessage\":\"suggested reply under 200 chars\"}\\n\\nReply: ' + message }],\n    contactId: contactId,\n    originalMessage: message,\n    profileUrl: parsed.profileUrl,\n    firstName: parsed.firstName || ''\n  }\n}];"
      }
    },
    {
      "id": "99cc4515-904c-45b3-a88f-d71c90a4a0d1",
      "name": "Claude - Classify Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [2250, 600],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "{{ANTHROPIC_API_KEY}}" },
            { "name": "anthropic-version", "value": "2023-06-01" },
            { "name": "content-type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ model: $json.model, max_tokens: $json.max_tokens, system: $json.system, messages: $json.messages }) }}",
        "contentType": "raw"
      }
    },
    {
      "id": "6249685b-d77e-4bb0-9943-dba037ec75b8",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2500, 600],
      "parameters": {
        "jsCode": "const text = $input.first().json.content?.[0]?.text?.trim() || '';\nconst classify = $('Build Classify Request').first().json;\nconst contactId = classify.contactId;\nconst originalMessage = classify.originalMessage;\nlet result;\ntry {\n  const clean = text.replace(/^```json\\s*/i, '').replace(/```\\s*$/, '').trim();\n  result = JSON.parse(clean);\n} catch {\n  result = { intent: 'other', responseMessage: '' };\n}\nreturn [{ json: {\n  intent: result.intent || 'other',\n  responseMessage: result.responseMessage || '',\n  contactId: contactId,\n  originalMessage: originalMessage\n} }];"
      }
    },
    {
      "id": "7a121c05-c6ad-49b0-bc5e-4566b3a8e5f7",
      "name": "Save Reply Note",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,

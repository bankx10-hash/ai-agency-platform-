          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ model: $json.model, max_tokens: $json.max_tokens, system: $json.system, messages: $json.messages }) }}",
        "contentType": "raw"
      }
    },
    {
      "id": "464c599f-594e-49ea-8cc8-73d8de8e232e",
      "name": "Parse Booking Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [4000, 600],
      "parameters": {
        "jsCode": "const reply = $input.first().json;\nconst buildNode = $('Build Booking Message').first().json;\nconst replyText = reply.content?.[0]?.text?.trim() || '';\nreturn [{ json: {\n  replyText,\n  contactId: buildNode.contactId,\n  contactName: buildNode.contactName,\n  contactEmail: buildNode.contactEmail,\n  originalMessage: buildNode.originalMessage,\n  bookingLink: buildNode.bookingLink\n} }];"
      }

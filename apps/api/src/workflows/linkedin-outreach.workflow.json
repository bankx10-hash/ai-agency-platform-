    {
      "id": "ae32de78-2ef8-40ad-8bb8-5207d17c77f8",
      "name": "Parse Profiles",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2000, 200],
      "parameters": {
        "jsCode": "// n8n splits JSON arrays into multiple items — use $input.all()\nconst items = $input.all();\nif (!items || items.length === 0) {\n  return [{ json: { skipped: true, reason: 'No profiles returned from Phantombuster' } }];\n}\nconst valid = items\n  .map(i => i.json)\n  .filter(p => p && (p.firstName || p.lastName || p.profileUrl));\nif (valid.length === 0) {\n  return [{ json: { skipped: true, reason: 'No profiles found' } }];\n}\nreturn valid.map(p => ({\n  json: {\n    firstName: p.firstName || '',\n    lastName: p.lastName || '',\n    fullName: p.fullName || ((p.firstName || '') + ' ' + (p.lastName || '')).trim() || 'Unknown',\n    headline: p.headline || p.title || p.occupation || '',\n    company: p.company || p.companyName || '',\n    location: p.location || '',\n    profileUrl: p.profileUrl || p.linkedInProfileUrl || '',\n    email: p.email || '',\n    connectedAt: p.connectedAt || p.timestamp || new Date().toISOString()\n  }\n}));"
      }
    },
    {
      "id": "if-has-profiles-001",
      "name": "IF - Has Profiles?",

    {
      "id": "pb-parse-conversation-001",
      "name": "Parse PB Conversation",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 600],
      "parameters": {
        "jsCode": "// Handles PhantomBuster fetch-output response: { data: { resultObject: '...' } }\nconst raw = $input.first().json;\nlet items = [];\n// fetch-output format\nconst resultObject = raw.data?.resultObject || raw.resultObject;\nif (resultObject) {\n  try { items = typeof resultObject === 'string' ? JSON.parse(resultObject) : resultObject; } catch { items = []; }\n} else if (typeof raw.output === 'string') {\n  try { items = JSON.parse(raw.output); } catch { items = []; }\n} else if (Array.isArray(raw.output)) {\n  items = raw.output;\n} else if (Array.isArray(raw)) {\n  items = raw;\n}\nif (!Array.isArray(items)) items = [];\n// Filter for inbound replies — Message Sender marks these as isIncoming or action === 'reply'\nconst incoming = items.filter(m =>\n  m.isIncoming === true ||\n  m.action === 'reply' ||\n  m.type === 'received' ||\n  (m.message && !m.sent)\n);\nif (incoming.length === 0) {\n  return [{ json: { skipped: true, reason: 'No incoming messages found' } }];\n}\nconst latest = incoming[incoming.length - 1];\nreturn [{ json: {\n  profileUrl: latest.profileUrl || latest.linkedinProfileUrl || '',\n  firstName: latest.firstName || '',\n  lastName: latest.lastName || '',\n  message: latest.message || latest.messageText || latest.text || '',\n  timestamp: latest.timestamp || latest.date || new Date().toISOString()\n} }];"
      }
    },
    {
      "id": "if-has-reply-001",
      "name": "IF - Has Reply?",
      "type": "n8n-nodes-base.if",

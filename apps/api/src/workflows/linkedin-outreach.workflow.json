            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "string",
        "body": "={{ JSON.stringify({ body: 'LinkedIn reply received. Intent: ' + $json.intent + '.\\nMessage: ' + $json.originalMessage + '\\nSuggested response: ' + $json.responseMessage }) }}",
        "contentType": "raw"
      }
    },
    {
      "id": "c01d7198-3e65-4905-947c-723acc848fc1",
      "name": "IF - Interested?",

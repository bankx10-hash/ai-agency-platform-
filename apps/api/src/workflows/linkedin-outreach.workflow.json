    {
      "id": "ae424431-8c18-4f2f-9f20-1f3a55796e74",
      "name": "Build Booking Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3500, 600],
      "parameters": {
        "jsCode": "const classification = $('Parse Classification').first().json;\nconst contactData = $input.first().json;\nconst contact = contactData.contact || contactData;\nconst name = contact.name || $('Build Classify Request').first().json.firstName || 'there';\nconst firstName = name.split(' ')[0];\nconst bookingLink = '{{BOOKING_LINK}}';\nreturn [{\n  json: {\n    model: 'claude-haiku-4-5-20251001',\n    max_tokens: 400,\n    system: 'You are a professional sales assistant for {{BUSINESS_NAME}}. Write a warm, concise LinkedIn reply (2-3 sentences max) that thanks the person for their interest, suggests a quick call to explore how you can help them, and naturally includes the booking link. Do NOT use generic filler phrases. Sound human and specific.',\n    messages: [{ role: 'user', content: 'Write a LinkedIn reply to ' + firstName + ' who responded positively to our outreach. Their message: \"' + classification.originalMessage + '\". Include this booking link: ' + bookingLink + '. Return ONLY the message text.' }],\n    contactId: classification.contactId,\n    contactName: name,\n    contactEmail: contact.email || '',\n    originalMessage: classification.originalMessage,\n    bookingLink: bookingLink\n  }\n}];"
      }
    },
    {
      "id": "5e23180d-73ba-4c23-bd87-bca6d285a1ae",
      "name": "Claude - Write Booking Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [3750, 600],
      "retryOnFail": true,
      "maxTries": 3,
      "waitBetweenTries": 5000,
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key", "value": "{{ANTHROPIC_API_KEY}}" },

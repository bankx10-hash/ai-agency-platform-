    {
      "id": "extract-s3-url-001",
      "name": "Extract S3 JSON URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1250, 200],
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst log = raw.output || raw.log || JSON.stringify(raw);\nconst match = String(log).match(/https:\\/\\/[^\\s'\"]+\\.json/);\nif (!match) {\n  return [{ json: { skipped: true, reason: 'No S3 JSON URL found in Phantombuster output' } }];\n}\nreturn [{ json: { jsonUrl: match[0] } }];"
      }
    },
    {
      "id": "if-has-url-001",
      "name": "IF - Has URL?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,

{
  "name": "Onboarding Master Workflow",
  "active": false,
  "nodes": [
    {
      "id": "onboarding-trigger",
      "name": "Onboarding Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "parameters": {
        "path": "onboarding-{{CLIENT_ID}}",
        "responseMode": "onReceived"
      },
      "webhookId": "onboarding-{{CLIENT_ID}}"
    },
    {
      "id": "deploy-agents",
      "name": "Trigger Agent Deployment",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [500, 300],
      "parameters": {
        "method": "POST",
        "url": "={{$env.API_BASE_URL}}/onboarding/{{CLIENT_ID}}/deploy-agents",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-secret", "value": "={{$env.N8N_API_SECRET}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"clientId\":\"{{CLIENT_ID}}\"}"
      }
    },
    {
      "id": "send-welcome",
      "name": "Send Welcome Email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [750, 300],
      "parameters": {
        "method": "POST",
        "url": "={{$env.API_BASE_URL}}/onboarding/{{CLIENT_ID}}/send-welcome",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-secret", "value": "={{$env.N8N_API_SECRET}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"clientId\":\"{{CLIENT_ID}}\"}"
      }
    },
    {
      "id": "mark-complete",
      "name": "Mark Onboarding Complete",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1000, 300],
      "parameters": {
        "method": "POST",
        "url": "={{$env.API_BASE_URL}}/onboarding/{{CLIENT_ID}}/complete",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-secret", "value": "={{$env.N8N_API_SECRET}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\"clientId\":\"{{CLIENT_ID}}\"}"
      }
    }
  ],
  "connections": {
    "Onboarding Trigger": {
      "main": [[{ "node": "Trigger Agent Deployment", "type": "main", "index": 0 }]]
    },
    "Trigger Agent Deployment": {
      "main": [[{ "node": "Send Welcome Email", "type": "main", "index": 0 }]]
    },
    "Send Welcome Email": {
      "main": [[{ "node": "Mark Onboarding Complete", "type": "main", "index": 0 }]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true
  }
}

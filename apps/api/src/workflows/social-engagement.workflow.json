        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  body: 'Social engagement via ' + $('Normalise Event').first().json.platform + ' (' + $('Normalise Event').first().json.type + '). Intent: ' + $('Analyse and Reply').first().json.intent + '. Message: ' + $('Normalise Event').first().json.message + '. Reply: ' + $('Analyse and Reply').first().json.reply\n}}",
        "options": {}
      },
      "id": "save-note",
      "name": "Save Conversation Note",
      "type": "n8n-nodes-base.httpRequest",

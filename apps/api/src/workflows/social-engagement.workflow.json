{
  "name": "Social Engagement Bot — {{BUSINESS_NAME}}",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "social-engage-{{CLIENT_ID}}",
        "options": {}
      },
      "id": "engagement-webhook",
      "name": "Engagement Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [0, 0],
      "webhookId": "social-engage-{{CLIENT_ID}}"
    },
    {
      "parameters": {
        "jsCode": "// Normalise the incoming event from Meta webhook forwarder\nconst body = $json.body || $json;\nconst type = body.type || 'dm';\nconst platform = body.platform || 'facebook';\nconst senderId = body.senderId || '';\nconst senderName = body.senderName || '';\nconst message = body.message || '';\nconst postId = body.postId || '';\nconst commentId = body.commentId || '';\nconst clientId = body.clientId || '{{CLIENT_ID}}';\n\n// Skip empty messages (likes, reactions with no text)\nif (!message.trim()) {\n  return [];\n}\n\nreturn [{ json: { type, platform, senderId, senderName, message, postId, commentId, clientId } }];"
      },
      "id": "normalise-event",
      "name": "Normalise Event",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [240, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{API_BASE_URL}}/n8n/{{CLIENT_ID}}/contacts",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-secret", "value": "{{N8N_API_SECRET}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  name: $('Normalise Event').first().json.senderName || $('Normalise Event').first().json.senderId,\n  email: $('Normalise Event').first().json.platform + '_' + $('Normalise Event').first().json.senderId + '@social.nodus',\n  source: $('Normalise Event').first().json.platform,\n  phone: ''\n}}",
        "options": {}
      },
      "id": "save-contact",
      "name": "Save Contact",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [480, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "{{API_BASE_URL}}/n8n/{{CLIENT_ID}}/social/analyse-engagement",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-secret", "value": "{{N8N_API_SECRET}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  type: $('Normalise Event').first().json.type,\n  platform: $('Normalise Event').first().json.platform,\n  senderId: $('Normalise Event').first().json.senderId,\n  senderName: $('Normalise Event').first().json.senderName,\n  message: $('Normalise Event').first().json.message,\n  postId: $('Normalise Event').first().json.postId,\n  commentId: $('Normalise Event').first().json.commentId\n}}",
        "options": {}
      },
      "id": "analyse-and-reply",
      "name": "Analyse and Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [720, 0]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.intent}}",
              "operation": "notEqual",
              "value2": "spam"
            }
          ]
        }
      },
      "id": "if-not-spam",
      "name": "IF Not Spam",

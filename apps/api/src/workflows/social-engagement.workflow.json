          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{\n  type: $('Normalise Event').first().json.type,\n  platform: $('Normalise Event').first().json.platform,\n  senderId: $('Normalise Event').first().json.senderId,\n  reply: $('Analyse and Reply').first().json.reply,\n  postId: $('Normalise Event').first().json.postId,\n  commentId: $('Normalise Event').first().json.commentId\n}}",
        "options": {}
      },
      "id": "send-reply",
      "name": "Send Reply",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1200, -120]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{$('Analyse and Reply').first().json.shouldBook}}",

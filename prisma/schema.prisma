// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  STARTER
  GROWTH
  AGENCY
}

enum ClientStatus {
  PENDING
  ACTIVE
  PAUSED
  CANCELLED
}

enum AgentStatus {
  INACTIVE
  ACTIVE
  PAUSED
  ERROR
}

enum OnboardingStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
}

enum AgentType {
  LEAD_GENERATION
  LINKEDIN_OUTREACH
  SOCIAL_MEDIA
  SOCIAL_ENGAGEMENT
  ADVERTISING
  APPOINTMENT_SETTER
  VOICE_INBOUND
  VOICE_OUTBOUND
  VOICE_CLOSER
  CLIENT_SERVICES
  CONVERSATIONAL_WORKFLOW
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum QuestionType {
  TEXT
  MULTIPLE_CHOICE
  OPEN_ENDED
  YES_NO
}

enum ConversationStatus {
  IN_PROGRESS
  COMPLETED
  QUALIFIED
  DISQUALIFIED
  TIMED_OUT
}

enum MessageChannel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
}

enum PipelineStage {
  NEW_LEAD
  CONTACTED
  QUALIFIED
  PROPOSAL
  CLOSED_WON
  CLOSED_LOST
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  SMS
  APPOINTMENT
  STAGE_CHANGE
  SCORE_CHANGE
  TASK_COMPLETED
  AGENT_ACTION
}

enum TaskStatus {
  PENDING
  DONE
  CANCELLED
}

model Client {
  id               String           @id @default(cuid())
  businessName     String
  email            String           @unique
  phone            String?
  passwordHash     String
  stripeCustomerId String           @unique
  stripeSubId      String?
  plan             Plan             @default(STARTER)
  status           ClientStatus     @default(PENDING)
  crmType             String?
  country             String?          @default("AU")
  businessDescription String?
  icpDescription      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  agents           AgentDeployment[]
  credentials      ClientCredential[]
  onboarding       Onboarding?
  contacts         Contact[]
  campaigns        Campaign[]
  funnels          Funnel[]
  workflows        ConversationWorkflow[]
  workflowConversations WorkflowConversation[]
}

model AgentDeployment {
  id            String      @id @default(cuid())
  clientId      String
  client        Client      @relation(fields: [clientId], references: [id])
  agentType     AgentType
  status        AgentStatus @default(INACTIVE)
  n8nWorkflowId String?
  retellAgentId String?
  config        Json
  metrics       Json?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ClientCredential {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id])
  service     String
  credentials String
  createdAt   DateTime @default(now())
}

model Onboarding {
  id          String           @id @default(cuid())
  clientId    String           @unique
  client      Client           @relation(fields: [clientId], references: [id])
  step        Int              @default(1)
  status      OnboardingStatus @default(IN_PROGRESS)
  completedAt DateTime?
  data        Json
}

// ── CRM Models ────────────────────────────────────────────────────────────────

model Contact {
  id              String          @id @default(cuid())
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String?
  email           String?
  phone           String?
  source          String?
  stage           String          @default("new")
  score           Int?
  tags            Json            @default("[]")
  summary         String?
  nextAction      String?
  crmId           String?
  pipelineStage   PipelineStage   @default(NEW_LEAD)
  dealValue       Decimal?        @db.Decimal(12, 2)
  dealCurrency    String          @default("AUD")
  lastContactedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  notes              ContactNote[]
  activities         ContactActivity[]
  tasks              ContactTask[]
  deals              Deal[]
  campaignRecipients CampaignRecipient[]

  @@index([clientId, pipelineStage])
  @@index([clientId, source])
  @@index([clientId, score])
  @@index([clientId, createdAt])
}

model ContactNote {
  id         String   @id @default(cuid())
  contactId  String
  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  body       String
  authorType String   @default("agent")
  createdAt  DateTime @default(now())

  @@index([contactId])
}

model ContactActivity {
  id         String       @id @default(cuid())
  contactId  String
  contact    Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  clientId   String
  type       ActivityType
  title      String
  body       String?
  metadata   Json?
  agentType  String?
  createdAt  DateTime     @default(now())

  @@index([contactId, createdAt])
  @@index([clientId, type])
}

model ContactTask {
  id          String     @id @default(cuid())
  contactId   String
  contact     Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  clientId    String
  title       String
  body        String?
  status      TaskStatus @default(PENDING)
  dueAt       DateTime?
  completedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([clientId, status, dueAt])
  @@index([contactId])
}

model Deal {
  id          String        @id @default(cuid())
  contactId   String
  contact     Contact       @relation(fields: [contactId], references: [id], onDelete: Cascade)
  clientId    String
  title       String
  value       Decimal?      @db.Decimal(12, 2)
  currency    String        @default("AUD")
  stage       PipelineStage @default(NEW_LEAD)
  probability Int?
  closedAt    DateTime?
  lostReason  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([clientId, stage])
  @@index([clientId, createdAt])
}

// ── Marketing Models ──────────────────────────────────────────────────────────

enum CampaignType {
  EMAIL
  SMS
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum RecipientStatus {
  PENDING
  SENT
  OPENED
  CLICKED
  FAILED
}

enum FunnelStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum StepType {
  LANDING
  OPT_IN
  UPSELL
  THANK_YOU
  SALES_PAGE
  WEBINAR
  CHECKOUT
}

model Campaign {
  id              String              @id @default(cuid())
  clientId        String
  client          Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name            String
  type            CampaignType
  subject         String?
  body            String
  status          CampaignStatus      @default(DRAFT)
  scheduledAt     DateTime?
  sentAt          DateTime?
  recipientFilter Json?
  stats           Json?
  recipients      CampaignRecipient[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([clientId, status])
  @@index([clientId, createdAt])
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  campaign   Campaign        @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactId  String
  contact    Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  status     RecipientStatus @default(PENDING)
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  error      String?

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
}

model Funnel {
  id          String             @id @default(cuid())
  clientId    String
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  description String?
  status      FunnelStatus       @default(DRAFT)
  steps       FunnelStep[]
  submissions FunnelSubmission[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([clientId, status])
}

model FunnelStep {
  id          String             @id @default(cuid())
  funnelId    String
  funnel      Funnel             @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  name        String
  type        StepType
  order       Int
  headline    String?
  subheadline String?
  body        String?
  ctaText     String?
  config      Json?
  submissions FunnelSubmission[]

  @@index([funnelId, order])
}

model FunnelSubmission {
  id        String      @id @default(cuid())
  funnelId  String
  funnel    Funnel      @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  stepId    String?
  step      FunnelStep? @relation(fields: [stepId], references: [id])
  contactId String?
  data      Json?
  ip        String?
  createdAt DateTime    @default(now())

  @@index([funnelId, createdAt])
  @@index([stepId])
}

// ── Conversational Workflow Models ────────────────────────────────────────────

model ConversationWorkflow {
  id                String              @id @default(cuid())
  clientId          String
  client            Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name              String
  description       String?
  status            WorkflowStatus      @default(DRAFT)
  channels          Json                @default("[]")
  qualifyThreshold  Int                 @default(70)
  welcomeMessage    String?
  completionMessage String?
  disqualifyMessage String?
  triggerKeywords   Json                @default("[]")
  triggerOn         Json                @default("[\"dm\"]")          // ["dm","comment","story_reply","story_mention"]
  commentReplyText  String?                                          // Auto-reply to the comment before DM
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  questions         WorkflowQuestion[]
  conversations     WorkflowConversation[]

  @@index([clientId, status])
}

model WorkflowQuestion {
  id           String               @id @default(cuid())
  workflowId   String
  workflow     ConversationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  order        Int
  questionText String
  questionType QuestionType         @default(TEXT)
  options      Json?
  scoreWeight  Int                  @default(0)
  crmField     String?
  isRequired   Boolean              @default(true)
  branchRules  Json?
  createdAt    DateTime             @default(now())

  @@index([workflowId, order])
}

model WorkflowConversation {
  id                String             @id @default(cuid())
  workflowId        String
  workflow          ConversationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  clientId          String
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  channel           MessageChannel
  senderId          String
  senderName        String?
  status            ConversationStatus @default(IN_PROGRESS)
  currentQuestionId String?
  score             Int                @default(0)
  answers           Json               @default("{}")
  extractedData     Json?
  contactId         String?
  startedAt         DateTime           @default(now())
  completedAt       DateTime?
  lastMessageAt     DateTime           @default(now())

  @@unique([workflowId, channel, senderId])
  @@index([clientId, status])
  @@index([senderId, channel])
}
